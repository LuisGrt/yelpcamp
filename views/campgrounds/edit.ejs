<% include ../partials/header %>
		<% include ../partials/navbar %>
		<section id="editCampground" class="container">
			<% if(error && error.length > 0) { %>
				<div class="alert alert-danger alert-dismissible" role="alert">
					<h4 class="alert-heading"><%-error[0]%></h4>
					<p><%-error[1]%></p>
					<button type="button" class="close" data-dismiss="alert" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
			<% } %>
			<div class="card">
				<h3>Edit <%=campground.name%></h3>
				<form action="/campgrounds/<%=campground._id%>?_method=PUT" method="POST">
					<div class="form-group">
						<label for="name">Name</label>
						<input class="form-control" type="text" name="campground[name]" id="name" value="<%=campground.name%>" required>
					</div>
					<div class="form-group">
						<label for="image">Image URL</label>
						<input class="form-control" type="text" name="campground[image]" id="image" value="<%=campground.image%>" required>
					</div>
					<div class="form-group">
						<label for="price">Price ($/night)</label>
						<input class="form-control" type="text" name="campground[price]" id="price" value="<%=campground.price%>">
					</div>
					<div class="form-group">
						<label for="address">Address</label>
						<input class="form-control" type="text" name="campground[address]" id="address" value="<%=campground.address%>">
					</div>
					<div class="form-group">
						<label for="description">Description</label>
						<textarea class="form-control" name="campground[description]" id="description" rows="6"><%=campground.description%></textarea>
					</div>
					<button type="submit" class="btn btn-primary btn-block">Submit</button>
				</form>
			</div>
			<a href="/campgrounds/<%=campground._id%>">Go back!</a>
		</section>
<% include ../partials/footer %>
